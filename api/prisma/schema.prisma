generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  FINANCIAL
  VIEWER
}

enum ClientStatus {
  NEW_LEAD
  FIRST_CONTACT_SENT
  EXPLANATION_SENT
  WAITING_INTEREST_CONFIRMATION
  COLLECTING_DATA
  WAITING_CPF
  WAITING_QUOTA_CHOICE
  QUOTA_RESERVED
  PAYMENT_LINK_SENT
  WAITING_PAYMENT
  PARTICIPANT
  NEEDS_HUMAN
  COLD
  WITHDRAWN
  DEFAULTED
  WINNER
  CANCELLED
}

enum GroupStatus {
  OPEN
  IN_PROGRESS
  PAUSED
  FINISHED
  CANCELLED
}

enum QuotaStatus {
  AVAILABLE
  RESERVED
  WAITING_PAYMENT
  ACTIVE
  DEFAULTED
  WINNER
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
  EXEMPT
}

enum DrawStatus {
  SCHEDULED
  DONE
  CANCELLED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageChannel {
  WHATSAPP
  KOMMO
  SYSTEM
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(OPERATOR)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
  draws        Draw[]     @relation("DrawCreatedBy")
}

model Client {
  id             String                @id @default(cuid())
  name           String
  phone          String
  email          String?
  cpf            String?
  origin         String?
  status         ClientStatus          @default(NEW_LEAD)
  kommoContactId String?
  kommoLeadId    String?
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  automation     Automation?
  automationEvents AutomationEvent[]
  conversationMessages ConversationMessage[]
  payments       Payment[]
  quotas         Quota[]
  drawsWon       Draw[]                @relation("DrawWinnerClient")

  @@index([status])
  @@index([phone])
}

model Group {
  id               String      @id @default(cuid())
  name             String
  description      String?
  quotaValue       Decimal     @db.Decimal(12, 2)
  quotaQuantity    Int
  prizeValue       Decimal?    @db.Decimal(12, 2)
  prizeDescription String?
  status           GroupStatus @default(OPEN)
  startDate        DateTime?
  endDate          DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  quotas           Quota[]
  payments         Payment[]
  draws            Draw[]
}

model Quota {
  id          String      @id @default(cuid())
  groupId     String
  clientId    String?
  number      Int
  status      QuotaStatus @default(AVAILABLE)
  reservedAt  DateTime?
  activatedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  payments    Payment[]
  drawsWon    Draw[]      @relation("DrawWinningQuota")

  @@unique([groupId, number])
  @@index([groupId, status])
  @@index([clientId])
}

model Payment {
  id                String        @id @default(cuid())
  clientId          String
  groupId           String
  quotaId           String?
  amount            Decimal       @db.Decimal(12, 2)
  dueDate           DateTime
  paidAt            DateTime?
  status            PaymentStatus @default(PENDING)
  method            String?
  paymentLink       String?
  externalPaymentId String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group             Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  quota             Quota?        @relation(fields: [quotaId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([clientId])
  @@index([groupId])
}

model Draw {
  id              String     @id @default(cuid())
  groupId         String
  title           String
  drawDate        DateTime
  drawnNumber     Int?
  winningQuotaId  String?
  winningClientId String?
  status          DrawStatus @default(SCHEDULED)
  notes           String?
  createdById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  group           Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  winningQuota    Quota?     @relation("DrawWinningQuota", fields: [winningQuotaId], references: [id], onDelete: SetNull)
  winningClient   Client?    @relation("DrawWinnerClient", fields: [winningClientId], references: [id], onDelete: SetNull)
  createdBy       User?      @relation("DrawCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([groupId])
  @@index([status])
}

model Automation {
  id             String   @id @default(cuid())
  clientId       String   @unique
  currentStep    String
  status         String
  lastMessageAt  DateTime?
  lastResponseAt DateTime?
  fallbackCount  Int      @default(0)
  humanRequired  Boolean  @default(false)
  finished       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([humanRequired])
}

model AutomationEvent {
  id        String   @id @default(cuid())
  clientId  String
  type      String
  message   String?
  payload   Json?
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([type])
}

model ConversationMessage {
  id        String           @id @default(cuid())
  clientId  String
  direction MessageDirection
  channel   MessageChannel
  message   String
  payload   Json?
  createdAt DateTime         @default(now())
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([channel])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  entity      String
  entityId    String?
  action      String
  description String
  payload     Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity])
  @@index([userId])
}

model KommoEvent {
  id        String   @id @default(cuid())
  eventType String
  externalId String?
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([processed])
}
